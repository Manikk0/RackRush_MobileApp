# Skopíruj tento súbor ako .env a vyplň vlastné hodnoty.

# --- PostgreSQL (povinné pre migrate, seed a beh servera) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rackrush
DB_USER=rackrush_app
DB_PASSWORD=change_me

# --- JWT (povinné pre auth) ---
JWT_SECRET=change_me_to_a_long_random_string
JWT_REFRESH_SECRET=change_me_to_another_long_random_string
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# --- HTTP server ---
PORT=3000
NODE_ENV=development

# --- Migrácia: true = pred schémou zmaže public schému (len vývoj!) ---
RESET_DB=false

# --- E-mail (voliteľné; bez SMTP sa reset link len vypíše do konzoly) ---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=no-reply@rackrush.local

# --- Odkazy v e-mailoch (voliteľné) ---
APP_BASE_URL=http://localhost:3000

# --- Push notifikácie (voliteľné): cesta k Firebase service account JSON ---
# GOOGLE_APPLICATION_CREDENTIALS=./path/to/serviceAccountKey.json